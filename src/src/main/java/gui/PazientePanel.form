<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.PazientePanel">
  <grid id="27dc6" binding="pazientePanel" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="20" left="20" bottom="20" right="20"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="ce9b9" class="javax.swing.JButton" binding="btnCartClin">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="VISUALIZZA CARTELLA CLINICA"/>
        </properties>
      </component>
      <component id="849fc" class="javax.swing.JButton" binding="btnPREN">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="EFFETTUA PRENOTAZIONE"/>
        </properties>
      </component>
      <component id="695b4" class="javax.swing.JLabel" binding="Titolopaz">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font name="Bookshelf Symbol 7" size="20" style="3"/>
          <text value="Area Personale - Paziente"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
